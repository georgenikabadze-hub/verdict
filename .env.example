# Copy to .env.local and fill in values. NEVER commit .env or .env.local.
# Each developer fetches their own keys; we do not share keys via git, Slack, or screenshots.

# --- Google Maps Platform (Solar API + 3D Tiles) ---
# https://console.cloud.google.com → enable Solar API + Map Tiles API
GOOGLE_MAPS_API_KEY=

# --- Google Gemini (via AI Studio) ---
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Tavily (optional; only if we re-enable live tariff lookup) ---
# https://app.tavily.com
TAVILY_API_KEY=

# --- Aikido (security scan; side-prize) ---
# https://app.aikido.dev → connect repo, no key needed in code
# (the scan is configured in Aikido UI, not in env)

# --- Vercel deploy hook (optional; CI/CD only) ---
VERCEL_DEPLOY_HOOK_URL=

# --- App config ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
